{
  "name": "auto-build",
  "private": true,
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development  wait-on http://localhost:5173 && electron --no-sandbox .",
    "electron:build": "electron-builder",
    "dev:electron": "concurrently \"npm run dev\" \"npm run electron:dev\""
  },
  "dependencies": {
    "antd": "^5.29.3",
    "cors": "^2.8.6",
    "electron-store": "^8.2.0",
    "express": "^4.22.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.8",
    "wait-on": "^9.0.4"
  }
}
